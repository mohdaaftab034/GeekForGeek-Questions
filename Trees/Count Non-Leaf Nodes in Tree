// GFG Link - https://www.geeksforgeeks.org/problems/count-non-leaf-nodes-in-tree/1?utm=codolio


// Solution --->
class Solution {
  public:
    
    int solve(Node* root) {
        if(root == NULL) return 0;
        
       
        if(root->left == NULL && root->right == NULL) {
            return 0;
        }
        
        int ans = 1 + solve(root->left) + solve(root->right);
        
        return ans;
    }
    
    int countNonLeafNodes(Node* root) {
        return solve(root);
    }
};
