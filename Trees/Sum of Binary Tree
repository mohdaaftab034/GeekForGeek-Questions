// Solution --->
class Solution {
  public:
    
    int solve(Node* root) {
        if(root == NULL) return 0;
        
        int ans = root -> data + solve(root -> right) + solve(root -> left);
        
        return ans;
    }
    
  
    int sumBT(Node* root) {
        return solve(root);
    }
};
